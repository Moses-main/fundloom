# Frontend (Vite) environment variables
# Copy this file to `.env` and fill in your values

# ---------------- Authentication ----------------
# Privy App ID (required when enabling Privy SDK)
VITE_PRIVY_APP_ID=
# Optional: override Privy browser SDK script URL
VITE_PRIVY_JS_SDK_URL=https://auth.privy.io/js/privy.js
# Dev only fallback for wallet auth when backend verify endpoints are unavailable
VITE_ALLOW_INSECURE_WALLET_SESSION=false

# Base URL for backend API (optional if you run auth + donations fully onchain/client-side)
# Keep /api/v1 if backend endpoints are enabled.
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Frontend base URL used for OAuth redirects (optional)
# VITE_FRONTEND_URL=http://localhost:5173

# ---------------- Wallet Connection ----------------
# WalletConnect Cloud Project ID (create at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# App metadata for wallet modals
VITE_APP_NAME=fundloom
VITE_APP_ICON_URL=
VITE_APP_DESCRIPTION=FundLoom – Seamless giving onchain

# Default target chain/network (ui default). Options: base, base-sepolia, celo, celo-alfajores, starknet, starknet-sepolia
VITE_DEFAULT_CHAIN=base-sepolia


# EVM smart contract integration
# Required for onchain donations and optional onchain campaign creation sync
VITE_EVM_CONTRACT_ADDRESS=
# Base Sepolia default = 0x14A34 (84532)
VITE_EVM_CHAIN_ID_HEX=0x14A34
# Optional ERC20 token addresses used for donation token selection
VITE_EVM_USDC_ADDRESS=
VITE_EVM_USDT_ADDRESS=
# Enable onchain createCampaign call from Create Campaign modal (requires wallet + contract)
VITE_ENABLE_ONCHAIN_CAMPAIGN_CREATE=false

# EVM RPC URLs (Base, Celo). Prefer providers (Alchemy/Infura/QuickNode/Blast). Public examples below may rate-limit.
# Base mainnet (example public): https://mainnet.base.org
VITE_RPC_BASE_MAINNET=
# Base Sepolia testnet (example public): https://sepolia.base.org
VITE_RPC_BASE_SEPOLIA=

# Celo mainnet (example public): https://forno.celo.org
VITE_RPC_CELO_MAINNET=
# Celo Alfajores testnet (example public): https://alfajores-forno.celo-testnet.org
VITE_RPC_CELO_ALFAJORES=

# StarkNet RPC URLs (JSON-RPC). Use a provider (e.g., Infura/Alchemy/Blast) for reliability.
# Example placeholders below.
VITE_RPC_STARKNET_MAINNET=
VITE_RPC_STARKNET_SEPOLIA=

# ---------------- Backend (Node.js + Express) ----------------
# Backend server port for local API
BACKEND_PORT=5001
# JWT signing key for backend-issued sessions (replace in production)
JWT_SECRET=change-me-in-production
# Planned DB connection string (Postgres recommended for production)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fundloom
